# Copy this file to .env and fill in real values before running docker compose.

# Password for the shared Postgres instance (user: postgres).
POSTGRES_PASSWORD=change-me

# Flask session secret for the web UI.
UI_SECRET_KEY=change-me-too

# Airflow web UI login (http://localhost:8080) and session secret.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-as-well
AIRFLOW_SECRET_KEY=change-me-airflow

# Shared API key the backend services require in the X-API-Key header.
# Leave empty to disable auth for local development.
SMARTGRID_API_KEY=change-me-api-key
